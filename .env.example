PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=postgresql://127.0.0.1:5432/template-ecommerce?sslmode=verify-full

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Cloudflare R2 media storage
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://<bucket-subdomain>.r2.dev/<bucket-name>

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# Cashfree API keys
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2025-01-01
NEXT_PUBLIC_CASHFREE_ENV=sandbox
